# Copy this file to .env and fill in your values (in our case, store these in Cloudflare Pages secrets)

VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# PostHog analytics (optional — analytics are disabled when this is unset)
VITE_POSTHOG_KEY="phc_your_project_api_key"
VITE_POSTHOG_HOST="https://eu.i.posthog.com"
