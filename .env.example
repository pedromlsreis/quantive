# Copy this file to .env and fill in your values. In production, store these
# in the hosting provider's secret store (e.g. Cloudflare Pages, Vercel, etc.)

VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# PostHog analytics (optional - analytics are disabled when this is unset)
VITE_POSTHOG_KEY="phc_your_project_api_key"
VITE_POSTHOG_HOST="https://eu.i.posthog.com"

# Cloudflare Turnstile CAPTCHA (optional). Public site key; widget renders only
# when set. The matching SECRET key goes in Supabase (Auth -> CAPTCHA), not here.
# Dev/E2E always-pass test key: 1x00000000000000000000AA
VITE_TURNSTILE_SITE_KEY=""

# E2E (Playwright) only — never used by the app bundle.
# The auth specs sign in via the Supabase admin path because the project
# enforces CAPTCHA on the password grant (a headless test can't solve it).
# TEST_USER_2_* is needed only by the account-swap spec.
TEST_USER_EMAIL="e2e-user-1@example.com"
TEST_USER_PASSWORD="your-test-user-password"
TEST_USER_2_EMAIL="e2e-user-2@example.com"
TEST_USER_2_PASSWORD="your-second-test-user-password"
# Service-role key from Supabase (Settings -> API). Grants the captcha-free
# admin sign-in used by the E2E auth helper. Keep it out of version control.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
